{
    "component": "Page",
    "props": {
        "auth": {
            "id": 1,
            "name": "Demo User",
            "email": "demo@middag.io",
            "capabilities": [
                "helpdesk:supervise"
            ]
        },
        "navigation": {
            "tree": [
                {
                    "key": "dashboard",
                    "label": "Dashboard",
                    "icon": "layout-dashboard",
                    "href": "/",
                    "children": []
                },
                {
                    "key": "tickets",
                    "label": "Tickets",
                    "icon": "inbox",
                    "href": "/tickets",
                    "children": []
                },
                {
                    "key": "agents",
                    "label": "Agents",
                    "icon": "users",
                    "href": "/agents",
                    "children": []
                },
                {
                    "key": "customers",
                    "label": "Customers",
                    "icon": "building",
                    "href": "/customers",
                    "children": []
                },
                {
                    "key": "parity",
                    "label": "Dual-ORM parity",
                    "icon": "columns",
                    "href": "/parity",
                    "children": []
                },
                {
                    "key": "coverage",
                    "label": "Coverage",
                    "icon": "shield-check",
                    "href": "/coverage",
                    "children": []
                },
                {
                    "key": "help",
                    "label": "Help",
                    "icon": "help-circle",
                    "href": "/help",
                    "children": []
                }
            ],
            "activeKey": "tickets",
            "footer": []
        },
        "version": "demo-0.5",
        "locale": "en",
        "theme": {
            "appearance": "light"
        },
        "flash": [],
        "errors": [],
        "csrf_token": "dev-csrf-token",
        "contract": {
            "version": "1",
            "shell": "basic",
            "page": {
                "key": "demo.tickets.create",
                "title": "New ticket",
                "subtitle": "Guided create — the wizard layout (StepIndicator + footer); server-driven stepping with the partial held in session"
            },
            "layout": {
                "template": "wizard",
                "regions": {
                    "content": [
                        {
                            "type": "form_panel",
                            "key": "ticket_form",
                            "data": {
                                "action": "/tickets/new",
                                "method": "post",
                                "schema": [
                                    {
                                        "kind": "field",
                                        "key": "subject",
                                        "component": "text",
                                        "props": {
                                            "label": "Subject",
                                            "required": true,
                                            "placeholder": "Short summary of the issue",
                                            "validation": {
                                                "maxLength": 200
                                            }
                                        }
                                    },
                                    {
                                        "kind": "field",
                                        "key": "body",
                                        "component": "textarea",
                                        "props": {
                                            "label": "Description",
                                            "required": false,
                                            "rows": 5,
                                            "validation": {
                                                "maxLength": 5000
                                            }
                                        }
                                    },
                                    {
                                        "kind": "field",
                                        "key": "channel",
                                        "component": "select",
                                        "props": {
                                            "label": "Channel",
                                            "required": true,
                                            "options": [
                                                {
                                                    "value": "email",
                                                    "label": "Email"
                                                },
                                                {
                                                    "value": "web",
                                                    "label": "Web"
                                                },
                                                {
                                                    "value": "phone",
                                                    "label": "Phone"
                                                }
                                            ]
                                        }
                                    },
                                    {
                                        "kind": "field",
                                        "key": "priority",
                                        "component": "select",
                                        "props": {
                                            "label": "Priority",
                                            "required": true,
                                            "options": [
                                                {
                                                    "value": "low",
                                                    "label": "Low"
                                                },
                                                {
                                                    "value": "normal",
                                                    "label": "Normal"
                                                },
                                                {
                                                    "value": "high",
                                                    "label": "High"
                                                },
                                                {
                                                    "value": "urgent",
                                                    "label": "Urgent"
                                                }
                                            ]
                                        }
                                    },
                                    {
                                        "kind": "field",
                                        "key": "customer_id",
                                        "component": "entity_picker",
                                        "props": {
                                            "label": "Customer",
                                            "required": true,
                                            "entityDisplayField": "label",
                                            "autocompleteHref": "/api/entities/customers"
                                        }
                                    },
                                    {
                                        "kind": "field",
                                        "key": "agent_id",
                                        "component": "entity_picker",
                                        "props": {
                                            "label": "Assignee",
                                            "required": false,
                                            "required_when": {
                                                "field": "priority",
                                                "operator": "in",
                                                "value": [
                                                    "high",
                                                    "urgent"
                                                ]
                                            },
                                            "entityDisplayField": "label",
                                            "autocompleteHref": "/api/entities/agents"
                                        }
                                    }
                                ],
                                "values": {
                                    "channel": "web",
                                    "priority": "normal"
                                },
                                "errors": [],
                                "meta": {
                                    "validation": "both",
                                    "submitLabel": "Continue",
                                    "cancelLabel": "Cancel",
                                    "cancelHref": "/tickets"
                                }
                            }
                        }
                    ]
                },
                "meta": {
                    "steps": [
                        {
                            "label": "Ticket",
                            "status": "active"
                        },
                        {
                            "label": "Schedule",
                            "status": "pending"
                        }
                    ],
                    "actions": []
                }
            }
        }
    },
    "url": "/tickets/new",
    "version": "demo-0.5"
}
