# Normalize line endings — LF in the repo, auto on checkout.
* text=auto eol=lf

# This is an example app (composer type "project"), not a distributed library,
# but keep dist archives lean and GitHub's language stats honest all the same.
/.cache                             export-ignore
/.claude                            export-ignore
/.githooks                          export-ignore
/.github                            export-ignore
/.gitattributes                     export-ignore
/.gitignore                         export-ignore
/.php-cs-fixer.dist.php             export-ignore
/.php-rector.php                    export-ignore
/.phpstan.neon                      export-ignore
/phpunit.xml                        export-ignore
/tests                              export-ignore
/docs                               export-ignore
/CLAUDE.md                          export-ignore
/CODE_OF_CONDUCT.md                 export-ignore
/CONTRIBUTING.md                    export-ignore

# Keep GitHub's language statistics accurate — documentation is not code.
*.md                                linguist-documentation
docs/**                             linguist-documentation
