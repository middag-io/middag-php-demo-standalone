{
  "name": "middag-io/demo-standalone",
  "description": "Demo harness — middag-io/framework + middag-io/ui consumed standalone (no Moodle/WP). Validates the ui 0.5.0 contract (full PageContract + partial Fragment) end-to-end and showcases Symfony console/lock/finder/filesystem integration.",
  "type": "project",
  "license": "Apache-2.0",
  "repositories": [
    {
      "type": "composer",
      "url": "https://privatesatis.middag.com.br"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "middag-io/framework": "^0.4.0",
    "middag-io/ui": "^0.6.0",
    "symfony/dotenv": "^7.0 || ^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "symfony/console": "^7.0 || ^8.0",
    "symfony/event-dispatcher": "^7.0 || ^8.0",
    "symfony/filesystem": "^7.0 || ^8.0",
    "symfony/finder": "^7.0 || ^8.0",
    "symfony/lock": "^7.0 || ^8.0"
  },
  "autoload": {
    "psr-4": {
      "Middag\\Demo\\Standalone\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Middag\\Demo\\Standalone\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "scripts": {
    "install:db": "@php bin/console install:db",
    "serve": "@php -S localhost:8080 -t public",
    "console": "@php bin/console",
    "outbox:drain": "@php bin/console outbox:drain",
    "migrate:discover": "@php bin/console migrate:discover",
    "test": "phpunit"
  }
}
