{
  "name": "middag-io/demo-standalone",
  "description": "Standalone harness proving the middag-io/framework OSS surface + middag-io/ui contracts — no Moodle/WordPress host, no proprietary core. Boots a real PSR-15 HTTP app (contract-driven Inertia, session auth + #[Auth] gate, middleware pipeline, CSRF, flash/PRG) + Symfony Console command worker over SQLite (Active Record + Data Mapper, converged Symfony Messenger bus, hooks, forms, schema migrations, logging).",
  "type": "project",
  "license": "Apache-2.0",
  "repositories": [
    {
      "type": "composer",
      "url": "https://privatesatis.middag.com.br"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "middag-io/framework": "^0.6.1",
    "middag-io/ui": "^0.6.3",
    "symfony/dotenv": "^7.0 || ^8.0"
  },
  "require-dev": {
    "doctrine/dbal": "^4.0",
    "filp/whoops": "^2.18",
    "phpunit/phpunit": "^11.0",
    "symfony/console": "^7.0 || ^8.0",
    "symfony/event-dispatcher": "^7.0 || ^8.0",
    "symfony/filesystem": "^7.0 || ^8.0",
    "symfony/finder": "^7.0 || ^8.0",
    "symfony/lock": "^7.0 || ^8.0",
    "symfony/var-dumper": "^8.1"
  },
  "autoload": {
    "psr-4": {
      "Middag\\Demo\\Standalone\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Middag\\Demo\\Standalone\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "scripts": {
    "install:db": "@php bin/console install:db",
    "serve": "@php -S localhost:8080 -t public public/index.php",
    "console": "@php bin/console",
    "worker:consume": "@php bin/console worker:consume",
    "logs:clean": "@php bin/console logs:clean",
    "migrate:discover": "@php bin/console migrate:discover",
    "test": "phpunit"
  }
}
