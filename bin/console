#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use Middag\Demo\Standalone\Bootstrap\DemoKernel;
use Middag\Demo\Standalone\Console\DebugRequestCommand;
use Middag\Demo\Standalone\Console\InstallCommand;
use Middag\Demo\Standalone\Console\LogsCleanCommand;
use Middag\Demo\Standalone\Console\MigrateDiscoverCommand;
use Middag\Demo\Standalone\Console\WorkerConsumeCommand;
use Symfony\Component\Console\Application;

$projectRoot = dirname(__DIR__);

$container = DemoKernel::boot($projectRoot);

$app = new Application('demo-standalone', '0.4.0');
$app->addCommands([
    new InstallCommand($container),
    new MigrateDiscoverCommand($projectRoot),
    new WorkerConsumeCommand($container),
    new LogsCleanCommand($container),
    new DebugRequestCommand($container),
]);
$app->run();
