parameters:
	ignoreErrors:
		-
			message: '#^Offset 0 on non\-empty\-list\<string\> on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: src/Bootstrap/DemoBootstrap.php

		-
			message: '#^Strict comparison using \!\=\= between mixed and null will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 5
			path: src/Command/CreateTicketCommand.php

		-
			message: '#^Strict comparison using \!\=\= between mixed and null will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 5
			path: src/Command/UpdateTicketCommand.php

		-
			message: '#^Strict comparison using \!\=\= between mixed and null will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 2
			path: src/Domain/Doctrine/CustomerMapper.php

		-
			message: '#^Method Middag\\Demo\\Standalone\\Form\\LoginForm\:\:schema\(\) has invalid return type Middag\\Ui\\Block\\LayoutElementInterface\.$#'
			identifier: class.notFound
			count: 1
			path: src/Form/LoginForm.php

		-
			message: '#^Method Middag\\Demo\\Standalone\\Form\\LoginForm\:\:schema\(\) has invalid return type Middag\\Ui\\Form\\FieldInterface\.$#'
			identifier: class.notFound
			count: 1
			path: src/Form/LoginForm.php

		-
			message: '#^Method Middag\\Demo\\Standalone\\Form\\LoginForm\:\:schema\(\) should return array\<int, Middag\\Ui\\Block\\LayoutElementInterface\|Middag\\Ui\\Form\\FieldInterface\> but returns array\<int, Middag\\Framework\\Form\\Field\\TextField\>\.$#'
			identifier: return.type
			count: 1
			path: src/Form/LoginForm.php

		-
			message: '#^Method Middag\\Demo\\Standalone\\Form\\TicketForm\:\:schema\(\) has invalid return type Middag\\Ui\\Block\\LayoutElementInterface\.$#'
			identifier: class.notFound
			count: 1
			path: src/Form/TicketForm.php

		-
			message: '#^Method Middag\\Demo\\Standalone\\Form\\TicketForm\:\:schema\(\) has invalid return type Middag\\Ui\\Form\\FieldInterface\.$#'
			identifier: class.notFound
			count: 1
			path: src/Form/TicketForm.php

		-
			message: '#^Method Middag\\Demo\\Standalone\\Form\\TicketForm\:\:schema\(\) should return array\<int, Middag\\Ui\\Block\\LayoutElementInterface\|Middag\\Ui\\Form\\FieldInterface\> but returns array\<int, Middag\\Framework\\Form\\Field\\DateField\|Middag\\Framework\\Form\\Field\\EntityPickerField\|Middag\\Framework\\Form\\Field\\SelectField\|Middag\\Framework\\Form\\Field\\TextareaField\|Middag\\Framework\\Form\\Field\\TextField\>\.$#'
			identifier: return.type
			count: 1
			path: src/Form/TicketForm.php

		-
			message: '#^Offset ''category'' on array\{category\: string, label\: string, context\: array\<string, mixed\>, duration_ms\: float\|null\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: src/Framework/DebugCollector.php

		-
			message: '#^Method Middag\\Demo\\Standalone\\Http\\TicketController\:\:formProps\(\) is unused\.$#'
			identifier: method.unused
			count: 1
			path: src/Http/TicketController.php

		-
			message: '#^Parameter \#4 \$schema of method Middag\\Ui\\Region\\RegionBuilder\:\:formPanel\(\) expects array\<string, mixed\>, list\<array\<string, mixed\>\> given\.$#'
			identifier: argument.type
			count: 1
			path: src/Http/TicketController.php

		-
			message: '#^Strict comparison using \!\=\= between ''closed''\|''open''\|''pending''\|''resolved'' and ''new'' will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 1
			path: src/Schema/HelpdeskSeeder.php
